{
  "name": "obsidian-cornell-notes",
  "version": "0.1.0",
  "description": "Cornell-style note layout for Obsidian using native callouts.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "node tests/build.mjs && node --test \"tests/dist/*.test.cjs\""
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "cornell-notes"
  ],
  "author": "Dell",
  "license": "GPL-3.0",
  "devDependencies": {
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@types/node": "^16.11.6",
    "builtin-modules": "3.3.0",
    "esbuild": "0.17.3",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "4.7.4"
  }
}
