{
  "name": "obsidian-cornell-notes",
  "version": "1.0.1",
  "description": "Cornell-style note layout for Obsidian using native callouts.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint main.ts classifier.ts livePreview.ts reviewMode.ts settings.ts",
    "test": "node tests/build.mjs && node --test \"tests/dist/*.test.cjs\""
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "cornell-notes"
  ],
  "author": "M-AbdullahTariq",
  "license": "GPL-3.0",
  "devDependencies": {
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@types/node": "^16.11.6",
    "@typescript-eslint/parser": "^8.60.1",
    "esbuild": "0.17.3",
    "eslint": "^10.4.1",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "4.7.4"
  }
}
